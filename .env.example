# Environment Configuration
# Copy this file to .env and fill in your values

# ─── Application ───────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=info
DEBUG=false

# ─── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=7860
WORKERS=1

# ─── Database ──────────────────────────────────────────────────────────────
DB_PATH=data/bharattechatlas.db

# ─── Redis Cache (Optional - enables distributed caching) ──────────────────
# Set REDIS_URL to enable Redis caching. If unset, falls back to in-memory.
# REDIS_URL=redis://localhost:6379/0
# REDIS_URL=redis://redis:6379/0

# ─── Security ──────────────────────────────────────────────────────────────
SECRET_KEY=change-this-in-production-to-a-random-256-bit-string
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_SEARCH=30/minute
RATE_LIMIT_CHAT=10/minute

# ─── ML / AI ──────────────────────────────────────────────────────────────
# HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google Maps (Optional - enables precise geocoding) ────────────────────
# GOOGLE_MAPS_API_KEY=AIzaSxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Data Enrichment (Optional - enables external data enrichment) ──────
# LINKEDIN_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxx
# CRUNCHBASE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# TRACXN_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Email / Notifications ─────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# ADMIN_EMAIL=admin@bharattechatlas.dev

# ─── Monitoring ────────────────────────────────────────────────────────────
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxx@xxxxxxx.ingest.sentry.io/xxxxxxx
# PROMETHEUS_PORT=9090
